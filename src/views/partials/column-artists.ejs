<div class="column-section">
  <div class="column-header-row">
    <h2>Artists</h2>
    <span class="badge"><%= locals.artists ? artists.length : 0 %></span>
  </div>
  <div class="results-list">
    <% if (locals.artists && artists.length > 0) { %>
      <% artists.forEach(artist => { %>
        <div class="result-item">
          <img src="<%= (artist.images && artist.images[0]) ? artist.images[0].url : '/placeholder-artist.png' %>" class="result-img circle" alt="">
          <div class="result-meta">
            <span class="result-title"><%= artist.name %></span>
            <span class="result-subtext"><%= (artist.genres && artist.genres.length > 0) ? artist.genres.slice(0, 2).join(', ') : 'Artist' %></span>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="no-results">No artists found.</p>
    <% } %>
  </div>
</div>